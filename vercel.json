{
  "builds": [{
    "src": "tattoo_project/wsgi.py",
    "use": "@vercel/python",
    "config": { "maxLambdaSize": "15mb", "runtime": "python3.12" }
  }],
  "routes": [{
    "src": "/(.*)",
    "dest": "tattoo_project/wsgi.py"
  }],
  "installCommand": "pip install -r requirements.txt && python manage.py migrate"
}